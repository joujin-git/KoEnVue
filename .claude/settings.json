{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opus",
  "effortLevel": "max",
  "alwaysThinkingEnabled": true,
  "showThinkingSummaries": true,
  "showTurnDuration": true,
  "spinnerTipsEnabled": false,
  "awaySummaryEnabled": true,
  "language": "korean",
  "includeCoAuthoredBy": false,
  "autoMemoryEnabled": true,
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "autoMemoryDirectory": "${CLAUDE_PROJECT_DIR}/.claude/memory",
  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1"
  },
  "statusLine": {
    "type": "command",
    "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File ${CLAUDE_PROJECT_DIR}/.claude/hooks/statusline.ps1"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File ${CLAUDE_PROJECT_DIR}/.claude/hooks/session-start.ps1",
            "timeout": 20
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File ${CLAUDE_PROJECT_DIR}/.claude/hooks/inject-ultrathink.ps1",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File ${CLAUDE_PROJECT_DIR}/.claude/hooks/post-edit-doc-sync.ps1",
            "timeout": 15
          }
        ]
      },
      {
        "_comment": "matcher=Bash 로 모든 Bash 호출에 발화 — auto-push.ps1 가 stdin tool_input.command 를 검사해 'git commit' 일 때만 실제 push 수행. Claude Code hook 스키마에 'if' 분기가 없어 스크립트 내부 필터로 통일.",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File ${CLAUDE_PROJECT_DIR}/.claude/hooks/auto-push.ps1",
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File ${CLAUDE_PROJECT_DIR}/.claude/hooks/stop-record.ps1",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File ${CLAUDE_PROJECT_DIR}/.claude/hooks/session-end.ps1",
            "timeout": 60
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File ${CLAUDE_PROJECT_DIR}/.claude/hooks/claude-md-size-check.ps1",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
