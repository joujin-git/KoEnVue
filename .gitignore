bin/
obj/
.vs/
*.user
*.suo
*.cache
*.log
publish/

# Secrets — auto wip commit + bypassPermissions = never accidentally commit these
*.env
*.env.*
secrets/
secrets.*
credentials*
*.pfx
*.p12
*.key
*.pem
.aws/
.azure/
.kube/
appsettings.Development.json
appsettings.Production.json
appsettings.Local.json
.env.local
.env.production
local.settings.json

# Claude Code harness — share configuration, hide ephemeral state
.claude/settings.local.json
.claude/worktrees/
.claude/state/
.claude/hooks/_tmp/
.claude/*.tmp
.claude/scratch/
# Safety guard: .claude/ 루트의 떠다니는 디버깅 ps1/txt 자동 무시
# (의도된 hook 들은 .claude/hooks/ 안에 있으므로 영향 없음)
.claude/*.ps1
.claude/*.txt
